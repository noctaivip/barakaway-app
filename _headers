/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/clear-cache.html
  Cache-Control: no-cache, no-store, must-revalidate

/css/*
  Cache-Control: no-cache, no-store, must-revalidate

/js/*
  Cache-Control: no-cache, no-store, must-revalidate

/assets/icons/*
  Cache-Control: no-cache, no-store, must-revalidate

/assets/screenshots/*
  Cache-Control: no-cache, no-store, must-revalidate
